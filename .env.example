# VITE_BASE44_APP_ID=your-base44-app-id
# VITE_BASE44_APP_BASE_URL=https://your-app-name.base44.app
# VITE_BASE44_FUNCTIONS_VERSION=latest

# PostHog analytics (requires cookie consent — "Accept all")
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error monitoring
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_ENABLED=true

# Stripe (frontend)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
# VITE_STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# VITE_STRIPE_PRICE_PREMIUM_PODCAST_MONTHLY=price_...
# VITE_STRIPE_PRICE_PREMIUM_YEARLY=price_...
# VITE_STRIPE_PRICE_PREMIUM_PODCAST_YEARLY=price_...

# LiveKit (browser streaming)
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Mux (OBS/RTMP streaming)
# VITE_MUX_ENABLED=true

# Base44 Secrets (set in Base44 Dashboard, NOT here):
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_ALLOWED_PRICES=price_xxx,price_yyy,...
# STRIPE_PLATFORM_FEE_PERCENT=10
# BASE44_APP_URL=https://your-app.base44.app
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
